{
  "fields": [
    { "path": "name", "from": "full_name", "type": "string", "required": true },
    { "path": "primary_email", "from": "emails[0]", "type": "string", "required": true },
    { "path": "mobile_phone", "from": "phones[0]", "type": "string", "required": true, "normalize": "E164" },
    { "path": "current_position", "from": "experience[0].title", "type": "string", "required": true },
    { "path": "current_company", "from": "experience[0].company", "type": "string", "required": true },
    { "path": "city", "from": "location.city", "type": "string", "required": false },
    { "path": "skills", "from": "skills", "type": "object", "required": true }
  ],
  "include_confidence": true,
  "include_provenance": false,
  "on_missing": "null"
}
